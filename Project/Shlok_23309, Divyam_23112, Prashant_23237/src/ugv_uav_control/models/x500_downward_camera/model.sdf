<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="x500_downward_camera">
    <static>false</static>
    
    <!-- Camera Link (The Anchor) -->
    <link name="camera_link">
      <pose>0 0 0 0 1.5707 0</pose> 
      <gravity>0</gravity>
      <inertial>
        <mass>0.1</mass>
        <inertia><ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.001</iyy><iyz>0</iyz><izz>0.001</izz></inertia>
      </inertial>
      
      <visual name="visual">
        <geometry><box><size>0.05 0.05 0.05</size></box></geometry>
        <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material>
      </visual>

      <sensor name="downward_camera" type="camera">
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image><width>640</width><height>480</height></image>
          <clip><near>0.1</near><far>100</far></clip>
        </camera>
        <always_on>1</always_on>
        <update_rate>20</update_rate>
        <visualize>true</visualize>
        <topic>drone/camera/image</topic>
      </sensor>
    </link>

    <!-- Include drone body -->
    <include>
      <name>drone_body</name>
      <uri>https://fuel.gazebosim.org/1.0/PX4/models/x500</uri>
    </include>

    <!-- Fixed joint to connect camera to drone -->
    <joint name="camera_joint" type="fixed">
      <parent>camera_link</parent>
      <child>drone_body::base_link</child>
    </joint>

    <!-- Movement and Telemetry Plugins -->
    <plugin filename="gz-sim-pose-publisher-system" name="gz::sim::systems::PosePublisher">
      <publish_link_pose>true</publish_link_pose>
      <publish_model_pose>true</publish_model_pose>
      <update_frequency>20</update_frequency>
    </plugin>

    <plugin filename="gz-sim-velocity-control-system" name="gz::sim::systems::VelocityControl">
      <topic>cmd_vel</topic>
    </plugin>
  </model>
</sdf>